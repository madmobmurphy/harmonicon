{
  "name": "react-example",
  "private": true,
  "version": "2.0.1",
  "type": "module",
  "main": "electron-main.js",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build",
    "build:server": "esbuild server.ts --bundle --platform=node --format=esm --define:process.env.NODE_ENV='\"production\"' --outfile=server.mjs --external:better-sqlite3 --external:discord-rpc \"--banner:js=import { createRequire } from 'module'; const require = createRequire(import.meta.url);\"",
    "preview": "vite preview",
    "clean": "rm -rf dist dist_desktop server.mjs",
    "lint": "tsc --noEmit",
    "dist": "npm run build && npm run build:server && electron-builder"
  },
  "build": {
    "appId": "com.ultimanobis.harmonicon",
    "productName": "Harmonicon",
    "asar": false,
    "files": [
      "**/*",
      "!server.ts",
      "!src/**/*",
      "!*.config.ts",
      "!tsconfig.json",
      "!dist_desktop"
    ],
    "directories": {
      "output": "dist_desktop"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.music"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm",
        "pacman"
      ],
      "icon": "build/icon.png",
      "category": "Audio"
    }
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.4.1",
    "dexie": "^4.3.0",
    "dexie-react-hooks": "^4.2.0",
    "discord-rpc": "^4.0.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.25.12",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
